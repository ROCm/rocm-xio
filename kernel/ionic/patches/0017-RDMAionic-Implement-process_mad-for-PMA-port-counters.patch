From 311536b89f83c3dd0a2c72d4ad9d5b7d8993b269 Mon Sep 17 00:00:00 2001
From: Stephen Bates <sbates@raithlin.com>
Date: Sat, 14 Mar 2026 16:51:37 -0600
Subject: [PATCH] RDMA/ionic: Implement process_mad for PMA port counters

The IB core only creates the mandatory counters/ sysfs directory
when the driver registers a process_mad callback. Without it,
standard monitoring tools (rdma_exporter, perfquery) cannot read
the mandatory IB port counters for ionic RoCE devices.

Implement a PMA-only process_mad handler that maps the ionic
firmware traffic counters to the standard IB port counter format:

  tx_rdma_ucast_bytes  -> port_xmit_data  (in 32-bit words)
  rx_rdma_ucast_bytes  -> port_rcv_data   (in 32-bit words)
  tx_rdma_ucast_pkts   -> port_xmit_packets
  rx_rdma_ucast_pkts   -> port_rcv_packets
  tx/rx_rdma_mcast_*   -> multicast counters (extended only)

The handler supports CLASS_PORT_INFO (advertising extended width
capability), PORT_COUNTERS (32-bit), and PORT_COUNTERS_EXT (64-bit)
queries. Counter values are cached during the periodic get_hw_stats
callback and served from the cache in process_mad.

This also fixes rdma_exporter compatibility: the exporter crashes
when the counters/ directory is absent, requiring a workaround of
excluding the ionic device.

Signed-off-by: Stephen Bates <sbates@raithlin.com>
---
 drivers/infiniband/hw/ionic/ionic_hw_stats.c | 137 ++++++++++++++++++-
 drivers/infiniband/hw/ionic/ionic_ibdev.h    |   4 +
 2 files changed, 139 insertions(+), 2 deletions(-)

diff --git a/drivers/infiniband/hw/ionic/ionic_hw_stats.c b/drivers/infiniband/hw/ionic/ionic_hw_stats.c
index 15ddf7d..ad2551d 100644
--- a/drivers/infiniband/hw/ionic/ionic_hw_stats.c
+++ b/drivers/infiniband/hw/ionic/ionic_hw_stats.c
@@ -2,6 +2,7 @@
 /* Copyright (C) 2018-2025, Advanced Micro Devices, Inc. */
 
 #include <linux/dma-mapping.h>
+#include <rdma/ib_pma.h>
 
 #include "ionic_fw.h"
 #include "ionic_ibdev.h"
@@ -45,6 +46,30 @@ static u64 ionic_sw_stat_val(struct ionic_ibdev *dev, int idx)
 	return (u64)atomic_read(&sw->watermark[cur]);
 }
 
+
+enum ionic_pma_idx {
+	IONIC_PMA_TX_BYTES,
+	IONIC_PMA_RX_BYTES,
+	IONIC_PMA_TX_PKTS,
+	IONIC_PMA_RX_PKTS,
+	IONIC_PMA_TX_MCAST_BYTES,
+	IONIC_PMA_RX_MCAST_BYTES,
+	IONIC_PMA_TX_MCAST_PKTS,
+	IONIC_PMA_RX_MCAST_PKTS,
+	IONIC_PMA_IDX_COUNT,
+};
+
+static const char * const ionic_pma_names[] = {
+	[IONIC_PMA_TX_BYTES]		= "tx_rdma_ucast_bytes",
+	[IONIC_PMA_RX_BYTES]		= "rx_rdma_ucast_bytes",
+	[IONIC_PMA_TX_PKTS]		= "tx_rdma_ucast_pkts",
+	[IONIC_PMA_RX_PKTS]		= "rx_rdma_ucast_pkts",
+	[IONIC_PMA_TX_MCAST_BYTES]	= "tx_rdma_mcast_bytes",
+	[IONIC_PMA_RX_MCAST_BYTES]	= "rx_rdma_mcast_bytes",
+	[IONIC_PMA_TX_MCAST_PKTS]	= "tx_rdma_mcast_pkts",
+	[IONIC_PMA_RX_MCAST_PKTS]	= "rx_rdma_mcast_pkts",
+};
+
 static int ionic_v1_stat_normalize(struct ionic_v1_stat *hw_stats,
 				   int hw_stats_count)
 {
@@ -274,6 +299,11 @@ static int ionic_get_hw_stats(struct ib_device *ibdev,
 		hw_stats->value[sw_base + sw_i] =
 			ionic_sw_stat_val(dev, sw_i);
 
+	for (sw_i = 0; sw_i < IONIC_PMA_IDX_COUNT; ++sw_i)
+		if (dev->pma_fw_idx[sw_i] >= 0)
+			dev->pma_vals[sw_i] =
+				hw_stats->value[dev->pma_fw_idx[sw_i]];
+
 	return sw_base + IONIC_SW_STAT_COUNT;
 
 err_cmd:
@@ -516,10 +546,111 @@ void ionic_sw_stat_dec(struct ionic_ibdev *dev, int idx)
 	atomic_dec(&dev->sw_stats.active[idx]);
 }
 
+
+static void ionic_pma_init(struct ionic_ibdev *dev)
+{
+	int i, j;
+
+	for (i = 0; i < IONIC_PMA_IDX_COUNT; i++) {
+		dev->pma_fw_idx[i] = -1;
+		for (j = 0; j < dev->hw_stats_count; j++) {
+			if (!strcmp(dev->hw_stats_hdrs[j].name,
+				   ionic_pma_names[i])) {
+				dev->pma_fw_idx[i] = j;
+				break;
+			}
+		}
+	}
+}
+
+static void ionic_pma_port_counters(struct ionic_ibdev *dev,
+				    struct ib_mad *out_mad)
+{
+	struct ib_pma_portcounters *pma;
+
+	pma = (struct ib_pma_portcounters *)(out_mad->data + 40);
+	memset(pma, 0, sizeof(*pma));
+	pma->port_select = 1;
+
+	pma->port_xmit_data = cpu_to_be32(
+		(u32)(dev->pma_vals[IONIC_PMA_TX_BYTES] / 4));
+	pma->port_rcv_data = cpu_to_be32(
+		(u32)(dev->pma_vals[IONIC_PMA_RX_BYTES] / 4));
+	pma->port_xmit_packets = cpu_to_be32(
+		(u32)dev->pma_vals[IONIC_PMA_TX_PKTS]);
+	pma->port_rcv_packets = cpu_to_be32(
+		(u32)dev->pma_vals[IONIC_PMA_RX_PKTS]);
+}
+
+static void ionic_pma_port_counters_ext(struct ionic_ibdev *dev,
+					struct ib_mad *out_mad)
+{
+	struct ib_pma_portcounters_ext *pma;
+
+	pma = (struct ib_pma_portcounters_ext *)(out_mad->data + 40);
+	memset(pma, 0, sizeof(*pma));
+	pma->port_select = 1;
+
+	pma->port_xmit_data = cpu_to_be64(
+		dev->pma_vals[IONIC_PMA_TX_BYTES] / 4);
+	pma->port_rcv_data = cpu_to_be64(
+		dev->pma_vals[IONIC_PMA_RX_BYTES] / 4);
+	pma->port_xmit_packets = cpu_to_be64(
+		dev->pma_vals[IONIC_PMA_TX_PKTS]);
+	pma->port_rcv_packets = cpu_to_be64(
+		dev->pma_vals[IONIC_PMA_RX_PKTS]);
+	pma->port_unicast_xmit_packets = cpu_to_be64(
+		dev->pma_vals[IONIC_PMA_TX_PKTS]);
+	pma->port_unicast_rcv_packets = cpu_to_be64(
+		dev->pma_vals[IONIC_PMA_RX_PKTS]);
+	pma->port_multicast_xmit_packets = cpu_to_be64(
+		dev->pma_vals[IONIC_PMA_TX_MCAST_PKTS]);
+	pma->port_multicast_rcv_packets = cpu_to_be64(
+		dev->pma_vals[IONIC_PMA_RX_MCAST_PKTS]);
+}
+
+static int ionic_process_mad(struct ib_device *ibdev,
+			     int mad_flags, u32 port_num,
+			     const struct ib_wc *in_wc,
+			     const struct ib_grh *in_grh,
+			     const struct ib_mad *in_mad,
+			     struct ib_mad *out_mad,
+			     size_t *out_mad_size,
+			     u16 *out_mad_pkey_index)
+{
+	struct ionic_ibdev *dev = to_ionic_ibdev(ibdev);
+	struct ib_class_port_info cpi = {};
+
+	if (in_mad->mad_hdr.mgmt_class != IB_MGMT_CLASS_PERF_MGMT)
+		return IB_MAD_RESULT_SUCCESS;
+
+	memcpy(out_mad, in_mad, sizeof(*out_mad));
+	out_mad->mad_hdr.method = IB_MGMT_METHOD_GET_RESP;
+
+	switch (in_mad->mad_hdr.attr_id) {
+	case IB_PMA_CLASS_PORT_INFO:
+		cpi.capability_mask =
+			IB_PMA_CLASS_CAP_EXT_WIDTH;
+		memcpy(out_mad->data + 40, &cpi, sizeof(cpi));
+		break;
+	case IB_PMA_PORT_COUNTERS:
+		ionic_pma_port_counters(dev, out_mad);
+		break;
+	case IB_PMA_PORT_COUNTERS_EXT:
+		ionic_pma_port_counters_ext(dev, out_mad);
+		break;
+	default:
+		return IB_MAD_RESULT_SUCCESS;
+	}
+
+	return IB_MAD_RESULT_SUCCESS | IB_MAD_RESULT_REPLY;
+}
+
 static const struct ib_device_ops ionic_hw_stats_ops = {
 	.driver_id = RDMA_DRIVER_IONIC,
 	.alloc_hw_port_stats = ionic_alloc_hw_stats,
 	.get_hw_stats = ionic_get_hw_stats,
+	.process_mad = ionic_process_mad,
 };
 
 static const struct ib_device_ops ionic_counter_stats_ops = {
@@ -542,12 +673,14 @@ void ionic_stats_init(struct ionic_ibdev *dev)
 				  "Failed to init hw stats\n");
 		} else {
 			rc = ionic_init_sw_stats(dev);
-			if (rc)
+			if (rc) {
 				ibdev_dbg(&dev->ibdev,
 					  "Failed to init sw stats\n");
-			else
+			} else {
+				ionic_pma_init(dev);
 				ib_set_device_ops(&dev->ibdev,
 						  &ionic_hw_stats_ops);
+			}
 		}
 	}
 
diff --git a/drivers/infiniband/hw/ionic/ionic_ibdev.h b/drivers/infiniband/hw/ionic/ionic_ibdev.h
index 1d12f13..a901a22 100644
--- a/drivers/infiniband/hw/ionic/ionic_ibdev.h
+++ b/drivers/infiniband/hw/ionic/ionic_ibdev.h
@@ -123,6 +123,10 @@ struct ionic_ibdev {
 	} sw_stats;
 
 	struct rdma_stat_desc	*hw_stats_hdrs_combined;
+
+	/* PMA counter mapping: firmware stat index per PMA counter */
+	int			pma_fw_idx[8];
+	u64			pma_vals[8];
 };
 
 struct ionic_eq {
-- 
2.43.0

