From 9c3065e5f9174720f2caac81b121253041563fb6 Mon Sep 17 00:00:00 2001
From: Stephen Bates <sbates@raithlin.com>
Date: Sat, 14 Mar 2026 16:44:09 -0600
Subject: [PATCH 16/16] RDMA/ionic: Wire up software resource counter tracking
 in create/destroy paths

Increment active_qps/cqs/pds/ahs/mrs on resource creation and
decrement on destruction. The counters are tracked via atomic_t
so no additional locking is needed.

The increment is placed after the resource is fully created
(post-command success) and the decrement after the resource is
fully torn down. For destroy paths that can fail (destroy_ah,
destroy_qp, destroy_cq), the decrement only occurs on success.

Signed-off-by: Stephen Bates <sbates@raithlin.com>
---
 .../infiniband/hw/ionic/ionic_controlpath.c   | 21 ++++++++++++++++++-
 1 file changed, 20 insertions(+), 1 deletion(-)

diff --git a/drivers/infiniband/hw/ionic/ionic_controlpath.c b/drivers/infiniband/hw/ionic/ionic_controlpath.c
index 9ce7c2e..3b5d2a4 100644
--- a/drivers/infiniband/hw/ionic/ionic_controlpath.c
+++ b/drivers/infiniband/hw/ionic/ionic_controlpath.c
@@ -487,8 +487,13 @@ int ionic_alloc_pd(struct ib_pd *ibpd, struct ib_udata *udata)
 {
 	struct ionic_ibdev *dev = to_ionic_ibdev(ibpd->device);
 	struct ionic_pd *pd = to_ionic_pd(ibpd);
+	int rc;
+
+	rc = ionic_get_pdid(dev, &pd->pdid);
+	if (!rc)
+		ionic_sw_stat_inc(dev, IONIC_RES_PD);
 
-	return ionic_get_pdid(dev, &pd->pdid);
+	return rc;
 }
 
 int ionic_dealloc_pd(struct ib_pd *ibpd, struct ib_udata *udata)
@@ -497,6 +502,7 @@ int ionic_dealloc_pd(struct ib_pd *ibpd, struct ib_udata *udata)
 	struct ionic_pd *pd = to_ionic_pd(ibpd);
 
 	ionic_put_pdid(dev, pd->pdid);
+	ionic_sw_stat_dec(dev, IONIC_RES_PD);
 
 	return 0;
 }
@@ -755,6 +761,8 @@ int ionic_create_ah(struct ib_ah *ibah, struct rdma_ah_init_attr *init_attr,
 			goto err_resp;
 	}
 
+	ionic_sw_stat_inc(dev, IONIC_RES_AH);
+
 	return 0;
 
 err_resp:
@@ -785,6 +793,7 @@ int ionic_destroy_ah(struct ib_ah *ibah, u32 flags)
 		return rc;
 
 	ionic_put_ahid(dev, ah->ahid);
+	ionic_sw_stat_dec(dev, IONIC_RES_AH);
 
 	return 0;
 }
@@ -916,6 +925,7 @@ struct ib_mr *ionic_reg_user_mr(struct ib_pd *ibpd, u64 start, u64 length,
 		goto err_cmd;
 
 	ionic_pgtbl_unbuf(dev, &mr->buf);
+	ionic_sw_stat_inc(dev, IONIC_RES_MR);
 
 	return &mr->ibmr;
 
@@ -1021,6 +1031,7 @@ int ionic_dereg_mr(struct ib_mr *ibmr, struct ib_udata *udata)
 		ib_umem_release(mr->umem);
 
 	ionic_put_mrid(dev, mr->mrid);
+	ionic_sw_stat_dec(dev, IONIC_RES_MR);
 
 out:
 	kfree(mr);
@@ -1266,6 +1277,8 @@ int ionic_create_cq(struct ib_cq *ibcq, const struct ib_cq_init_attr *attr,
 			goto err_resp;
 	}
 
+	ionic_sw_stat_inc(dev, IONIC_RES_CQ);
+
 	return 0;
 
 err_resp:
@@ -1307,6 +1320,9 @@ int ionic_destroy_cq(struct ib_cq *ibcq, struct ib_udata *udata)
 		ionic_destroy_cq_common(dev, &vcq->cq[udma_idx]);
 	}
 
+	if (!rc)
+		ionic_sw_stat_dec(dev, IONIC_RES_CQ);
+
 	return rc;
 }
 
@@ -2366,6 +2382,8 @@ int ionic_create_qp(struct ib_qp *ibqp, struct ib_qp_init_attr *attr,
 		qp->rq_cqid = cq->cqid;
 	}
 
+	ionic_sw_stat_inc(dev, IONIC_RES_QP);
+
 	return 0;
 
 err_resp:
@@ -2674,6 +2692,7 @@ int ionic_destroy_qp(struct ib_qp *ibqp, struct ib_udata *udata)
 		kfree(qp->hdr);
 	}
 	ionic_put_qpid(dev, qp->qpid);
+	ionic_sw_stat_dec(dev, IONIC_RES_QP);
 
 	return 0;
 }
