# Run a series of tests against one real and one emulated NVMe device

# Don't use set -e so all tests run even if one fails

NVME_EMUL=${NVME_EMUL:-/dev/nvme0}
NVME_REAL=${NVME_REAL:-/dev/nvme1}

NVME_EMUL_SHORT=${NVME_EMUL#/dev/}
NVME_REAL_SHORT=${NVME_REAL#/dev/}

# Check if emulated NVMe tests should be skipped
SKIP_EMULATED=false
if [ "$NVME_EMUL" = "none" ] || [ "$NVME_EMUL" = "NONE" ]; then
    SKIP_EMULATED=true
fi

# Check if passthrough NVMe tests should be skipped
SKIP_PASSTHROUGH=false
if [ "$NVME_REAL" = "none" ] || [ "$NVME_REAL" = "NONE" ]; then
    SKIP_PASSTHROUGH=true
fi

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Create temp directory for test logs
TEMP_DIR="${TEMP_DIR:-/tmp/nvme-ep-test}"
mkdir -p "$TEMP_DIR"

# Print test configuration
if [ "$SKIP_EMULATED" = "true" ]; then
    echo -e "${YELLOW}Skipping emulated NVMe tests (NVME_EMUL=none)${NC}"
    echo ""
fi
if [ "$SKIP_PASSTHROUGH" = "true" ]; then
    echo -e "${YELLOW}Skipping passthrough NVMe tests (NVME_REAL=none)${NC}"
    echo ""
fi

# Function to run a test and capture output
run_test() {
    local test_name="$1"
    local test_log="$TEMP_DIR/test_${test_name}.log"
    local test_params="$2"
    shift 2
    
    # Run test, redirecting stdout to log file
    # Capture stderr separately to extract PASS/FAIL messages
    local test_stderr=$(mktemp)
    local exit_code=0
    "$@" > "$test_log" 2>"$test_stderr" || exit_code=$?
    
    # Extract PASS/FAIL line from stderr (test script outputs it there)
    # Pattern matches PASS or FAIL even with color codes
    local result_line=$(grep -E "(PASS|FAIL):" "$test_stderr" 2>/dev/null | head -1 || echo "")
    if [ -n "$result_line" ]; then
        # Display the result line (it already has color codes)
        echo "$result_line"
    else
        # Fallback if no PASS/FAIL found
        if [ $exit_code -eq 0 ]; then
            echo -e "${GREEN}PASS${NC}: $test_params"
        else
            echo -e "${RED}FAIL${NC}: $test_params"
            echo "  Log: $test_log"
        fi
    fi
    
    rm -f "$test_stderr"
    return $exit_code
}

# Track overall test results
TESTS_PASSED=0
TESTS_FAILED=0
FAILED_TESTS=()

# Test emulated NVMe with host queues and data buffers
if [ "$SKIP_EMULATED" = "false" ]; then
    seed1=$(openssl rand -hex 2)
    if run_test "${NVME_EMUL_SHORT}_host_mem" \
        "${NVME_EMUL_SHORT} host-mem write=1 seed=0x${seed1} pci-mmio" \
        bash -c "WRITE_IO=1 MEMORY_MODE=0 LFSR_SEED=0x${seed1} \
          ./scripts/test/test-nvme-ep-data-verification.sh ${NVME_EMUL}"; then
        ((TESTS_PASSED++))
    else
        ((TESTS_FAILED++))
        FAILED_TESTS+=("${NVME_EMUL_SHORT}_host_mem")
    fi

    # Test emulated NVMe with device memory
    seed2=$(openssl rand -hex 2)
    if run_test "${NVME_EMUL_SHORT}_device_mem" \
        "${NVME_EMUL_SHORT} device-mem write=2 seed=0x${seed2} base_lba=1024 pci-mmio" \
        bash -c "WRITE_IO=2 MEMORY_MODE=8 LFSR_SEED=0x${seed2} BASE_LBA=1024 \
          ./scripts/test/test-nvme-ep-data-verification.sh ${NVME_EMUL}"; then
        ((TESTS_PASSED++))
    else
        ((TESTS_FAILED++))
        FAILED_TESTS+=("${NVME_EMUL_SHORT}_device_mem")
    fi

    # Test emulated NVMe with device memory and queues
    seed3=$(openssl rand -hex 2)
    if run_test "${NVME_EMUL_SHORT}_device_mem_queues" \
        "${NVME_EMUL_SHORT} device-mem-queues write=2 seed=0x${seed3} base_lba=1024 pci-mmio" \
        bash -c "WRITE_IO=2 MEMORY_MODE=11 LFSR_SEED=0x${seed3} BASE_LBA=1024 \
          ./scripts/test/test-nvme-ep-data-verification.sh ${NVME_EMUL}"; then
        ((TESTS_PASSED++))
    else
        ((TESTS_FAILED++))
        FAILED_TESTS+=("${NVME_EMUL_SHORT}_device_mem_queues")
    fi
fi

# Test passthrough NVMe with host memory
if [ "$SKIP_PASSTHROUGH" = "false" ]; then
    seed4=$(openssl rand -hex 2)
    if run_test "${NVME_REAL_SHORT}_host_mem" \
        "${NVME_REAL_SHORT} host-mem write=1 seed=0x${seed4} base_lba=4096 pci-mmio" \
        bash -c "WRITE_IO=1 MEMORY_MODE=0 LFSR_SEED=0x${seed4} BASE_LBA=4096 \
          ./scripts/test/test-nvme-ep-data-verification.sh ${NVME_REAL}"; then
        ((TESTS_PASSED++))
    else
        ((TESTS_FAILED++))
        FAILED_TESTS+=("${NVME_REAL_SHORT}_host_mem")
    fi

    # Test passthrough NVMe with device memory
    seed5=$(openssl rand -hex 2)
    if run_test "${NVME_REAL_SHORT}_device_mem" \
        "${NVME_REAL_SHORT} device-mem write=2 seed=0x${seed5} pci-mmio" \
        bash -c "WRITE_IO=2 MEMORY_MODE=8 LFSR_SEED=0x${seed5} \
          ./scripts/test/test-nvme-ep-data-verification.sh ${NVME_REAL}"; then
        ((TESTS_PASSED++))
    else
        ((TESTS_FAILED++))
        FAILED_TESTS+=("${NVME_REAL_SHORT}_device_mem")
    fi

    # Test passthrough NVMe with device memory and queues
    seed6=$(openssl rand -hex 2)
    if run_test "${NVME_REAL_SHORT}_device_mem_queues" \
        "${NVME_REAL_SHORT} device-mem-queues write=2 seed=0x${seed6} pci-mmio" \
        bash -c "WRITE_IO=2 MEMORY_MODE=11 LFSR_SEED=0x${seed6} \
          ./scripts/test/test-nvme-ep-data-verification.sh ${NVME_REAL}"; then
        ((TESTS_PASSED++))
    else
        ((TESTS_FAILED++))
        FAILED_TESTS+=("${NVME_REAL_SHORT}_device_mem_queues")
    fi

    # Test passthrough NVMe with host memory (direct doorbell)
    seed7=$(openssl rand -hex 2)
    if run_test "${NVME_REAL_SHORT}_host_mem_direct" \
        "${NVME_REAL_SHORT} host-mem write=1 seed=0x${seed7} direct" \
        bash -c "WRITE_IO=1 USE_PCI_MMIO_BRIDGE=0 MEMORY_MODE=0 \
          LFSR_SEED=0x${seed7} \
          ./scripts/test/test-nvme-ep-data-verification.sh ${NVME_REAL}"; then
        ((TESTS_PASSED++))
    else
        ((TESTS_FAILED++))
        FAILED_TESTS+=("${NVME_REAL_SHORT}_host_mem_direct")
    fi

    # Test passthrough NVMe with device memory (direct doorbell)
    seed8=$(openssl rand -hex 2)
    if run_test "${NVME_REAL_SHORT}_device_mem_direct" \
        "${NVME_REAL_SHORT} device-mem write=2 seed=0x${seed8} direct" \
        bash -c "WRITE_IO=2 USE_PCI_MMIO_BRIDGE=0 MEMORY_MODE=8 LFSR_SEED=0x${seed8} \
          ./scripts/test/test-nvme-ep-data-verification.sh ${NVME_REAL}"; then
        ((TESTS_PASSED++))
    else
        ((TESTS_FAILED++))
        FAILED_TESTS+=("${NVME_REAL_SHORT}_device_mem_direct")
    fi

    # Test passthrough NVMe with device memory and queues (direct doorbell)
    seed9=$(openssl rand -hex 2)
    if run_test "${NVME_REAL_SHORT}_device_mem_direct_queues" \
        "${NVME_REAL_SHORT} device-mem-queues write=2 seed=0x${seed9} direct" \
        bash -c "WRITE_IO=2 USE_PCI_MMIO_BRIDGE=0 MEMORY_MODE=11 LFSR_SEED=0x${seed9} \
          ./scripts/test/test-nvme-ep-data-verification.sh ${NVME_REAL}"; then
        ((TESTS_PASSED++))
    else
        ((TESTS_FAILED++))
        FAILED_TESTS+=("${NVME_REAL_SHORT}_device_mem_direct_queues")
    fi
fi

# Print summary
echo ""
echo "========================================"
echo "Test Summary"
echo "========================================"
echo "  Passed: $TESTS_PASSED"
echo "  Failed: $TESTS_FAILED"
echo "  Logs:   $TEMP_DIR"
if [ ${#FAILED_TESTS[@]} -gt 0 ]; then
    echo ""
    echo "Failed tests:"
    for test in "${FAILED_TESTS[@]}"; do
        echo "  - $test (log: $TEMP_DIR/test_${test}.log)"
    done
fi

# Exit with error if any tests failed
if [ $TESTS_FAILED -gt 0 ]; then
    exit 1
fi
exit 0
