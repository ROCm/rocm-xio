#!/bin/bash

# Don't use set -e so all tests run even if one fails

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Create temp directory for test logs
TEMP_DIR="${TEMP_DIR:-/tmp/nvme-ep-test}"
mkdir -p "$TEMP_DIR"

# Function to run a test and capture output
run_test() {
    local test_name="$1"
    local test_log="$TEMP_DIR/test_${test_name}.log"
    local test_params="$2"
    shift 2
    
    # Run test, redirecting stdout to log file
    # Capture stderr separately to extract PASS/FAIL messages
    local test_stderr=$(mktemp)
    local exit_code=0
    "$@" > "$test_log" 2>"$test_stderr" || exit_code=$?
    
    # Extract PASS/FAIL line from stderr (test script outputs it there)
    # Pattern matches PASS or FAIL even with color codes
    local result_line=$(grep -E "(PASS|FAIL):" "$test_stderr" 2>/dev/null | head -1 || echo "")
    if [ -n "$result_line" ]; then
        # Display the result line (it already has color codes)
        echo "$result_line"
    else
        # Fallback if no PASS/FAIL found
        if [ $exit_code -eq 0 ]; then
            echo -e "${GREEN}PASS${NC}: $test_params"
        else
            echo -e "${RED}FAIL${NC}: $test_params"
            echo "  Log: $test_log"
        fi
    fi
    
    rm -f "$test_stderr"
    return $exit_code
}

# Track overall test results
TESTS_PASSED=0
TESTS_FAILED=0
FAILED_TESTS=()

# Test emulated NVMe with host queues and data buffers
seed1=$(openssl rand -hex 2)
if run_test "nvme0_host_mem" \
    "nvme0 host-mem write=1 seed=0x${seed1} pci-mmio" \
    bash -c "WRITE_IO=1 MEMORY_MODE=0 LFSR_SEED=0x${seed1} \
      ./scripts/test/test-nvme-ep-data-verification.sh /dev/nvme0"; then
    ((TESTS_PASSED++))
else
    ((TESTS_FAILED++))
    FAILED_TESTS+=("nvme0_host_mem")
fi

# Test emulated NVMe with device memory
seed2=$(openssl rand -hex 2)
if run_test "nvme0_device_mem" \
    "nvme0 device-mem write=2 seed=0x${seed2} base_lba=1024 pci-mmio" \
    bash -c "WRITE_IO=2 MEMORY_MODE=8 LFSR_SEED=0x${seed2} BASE_LBA=1024 \
      ./scripts/test/test-nvme-ep-data-verification.sh /dev/nvme0"; then
    ((TESTS_PASSED++))
else
    ((TESTS_FAILED++))
    FAILED_TESTS+=("nvme0_device_mem")
fi

# Test passthrough NVMe with host memory
seed3=$(openssl rand -hex 2)
if run_test "nvme1_host_mem" \
    "nvme1 host-mem write=1 seed=0x${seed3} base_lba=4096 pci-mmio" \
    bash -c "WRITE_IO=1 MEMORY_MODE=0 LFSR_SEED=0x${seed3} BASE_LBA=4096 \
      ./scripts/test/test-nvme-ep-data-verification.sh /dev/nvme1"; then
    ((TESTS_PASSED++))
else
    ((TESTS_FAILED++))
    FAILED_TESTS+=("nvme1_host_mem")
fi

# Test passthrough NVMe with device memory
seed4=$(openssl rand -hex 2)
if run_test "nvme1_device_mem" \
    "nvme1 device-mem write=2 seed=0x${seed4} pci-mmio" \
    bash -c "WRITE_IO=2 MEMORY_MODE=8 LFSR_SEED=0x${seed4} \
      ./scripts/test/test-nvme-ep-data-verification.sh /dev/nvme1"; then
    ((TESTS_PASSED++))
else
    ((TESTS_FAILED++))
    FAILED_TESTS+=("nvme1_device_mem")
fi

# Test passthrough NVMe with host memory (direct doorbell)
seed5=$(openssl rand -hex 2)
if run_test "nvme1_host_mem_direct" \
    "nvme1 host-mem write=1 seed=0x${seed5} direct" \
    bash -c "WRITE_IO=1 USE_PCI_MMIO_BRIDGE=0 MEMORY_MODE=0 \
      LFSR_SEED=0x${seed5} \
      ./scripts/test/test-nvme-ep-data-verification.sh /dev/nvme1"; then
    ((TESTS_PASSED++))
else
    ((TESTS_FAILED++))
    FAILED_TESTS+=("nvme1_host_mem_direct")
fi

# Test passthrough NVMe with device memory (direct doorbell)
seed6=$(openssl rand -hex 2)
if run_test "nvme1_device_mem_direct" \
    "nvme1 device-mem write=2 seed=0x${seed6} direct" \
    bash -c "WRITE_IO=2 USE_PCI_MMIO_BRIDGE=0 MEMORY_MODE=8 LFSR_SEED=0x${seed6} \
      ./scripts/test/test-nvme-ep-data-verification.sh /dev/nvme1"; then
    ((TESTS_PASSED++))
else
    ((TESTS_FAILED++))
    FAILED_TESTS+=("nvme1_device_mem_direct")
fi

# Print summary
echo ""
echo "========================================"
echo "Test Summary"
echo "========================================"
echo "  Passed: $TESTS_PASSED"
echo "  Failed: $TESTS_FAILED"
echo "  Logs:   $TEMP_DIR"
if [ ${#FAILED_TESTS[@]} -gt 0 ]; then
    echo ""
    echo "Failed tests:"
    for test in "${FAILED_TESTS[@]}"; do
        echo "  - $test (log: $TEMP_DIR/test_${test}.log)"
    done
fi

# Exit with error if any tests failed
if [ $TESTS_FAILED -gt 0 ]; then
    exit 1
fi
exit 0