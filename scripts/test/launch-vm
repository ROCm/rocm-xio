#!/bin/bash
#
# launch-vm
#
# Launch a QEMU VM for rocm-xio testing. This is a thin
# wrapper around qemu-minimal's run-vm script.
#
# Usage:
#   ./launch-vm [rdma|nvme|ernic|full]
#
# Modes:
#   rdma  - GPU + BNXT NIC passthrough (default)
#   nvme  - GPU + NVMe controller + PCI MMIO bridge
#   ernic - GPU passthrough + emulated RDMA NIC via
#           rocm-ernic (VFIO-user sockets)
#   full  - GPU + BNXT NIC + NVMe passthrough +
#           rocm-ernic (all devices combined)
#
# All modes always include an emulated NVMe and the
# PCI MMIO bridge so nvme-ep and emulated RDMA NIC
# testing is available regardless of mode.
#
# Environment variables:
#   SSH_PORT        SSH forwarding port (default: 2222)
#   GPU_BDF         GPU PCI BDF (default: 10:00.0)
#   RDMA_NIC_BDF    BNXT NIC BDF for rdma mode
#                   (default: c3:00.1)
#   NVME_DEV_BDF    NVMe controller BDF for nvme mode
#                   (default: 85:00.0)
#   ERNIC_BIN       Path to rocm-ernic binary
#   ERNIC_INSTANCES Number of ERNIC instances
#                   (default: 1)
#   ERNIC_BACKEND   ERNIC backend (default: loopback)
#   RUN_VM          Path to qemu-minimal run-vm script
#   QEMU_PATH       Path prefix for QEMU binary
#   VCPUS           Number of vCPUs (default: 16)
#   VMEM            VM memory in MB (default: 32768)

set -e


MODE="${1:-${VM_MODE:-rdma}}"
SSH_PORT="${SSH_PORT:-2222}"
GPU_BDF="${GPU_BDF:-10:00.0}"
RDMA_NIC_BDF="${RDMA_NIC_BDF:-c3:00.1}"
NVME_DEV_BDF="${NVME_DEV_BDF:-85:00.0}"
VCPUS="${VCPUS:-16}"
VMEM="${VMEM:-32768}"

ERNIC_BIN="${ERNIC_BIN:-}"
ERNIC_INSTANCES="${ERNIC_INSTANCES:-1}"
ERNIC_BACKEND="${ERNIC_BACKEND:-loopback}"

RUN_VM="${RUN_VM:-${HOME}/Projects/qemu-minimal/qemu/run-vm}"

RUN_VM_DIR="$(dirname "${RUN_VM}")"
IMAGES="${RUN_VM_DIR}/../images"

ERNIC_PIDS=()

cleanup() {
    for pid in "${ERNIC_PIDS[@]}"; do
        if kill -0 "${pid}" 2>/dev/null; then
            echo "Stopping rocm-ernic (pid ${pid})..."
            kill "${pid}" 2>/dev/null || true
            wait "${pid}" 2>/dev/null || true
        fi
    done
    for sock in /tmp/vfio-user-rocm-ernic-*.sock; do
        [ -S "${sock}" ] && rm -f "${sock}"
    done
}

check_vfio_binding() {
    local bdf="$1"
    local sysfs="/sys/bus/pci/devices/0000:${bdf}"

    if [ ! -e "${sysfs}" ]; then
        echo "ERROR: PCI device ${bdf} not found."
        echo "  Check lspci output for valid BDFs."
        exit 1
    fi

    local driver=""
    if [ -L "${sysfs}/driver" ]; then
        driver="$(basename \
          "$(readlink "${sysfs}/driver")")"
    fi

    if [ "${driver}" != "vfio-pci" ]; then
        echo "ERROR: ${bdf} is bound to" \
             "'${driver:-none}', not vfio-pci."
        echo "  Bind with:"
        echo "    sudo driverctl set-override" \
             "0000:${bdf} vfio-pci"
        echo "  To restore later:"
        echo "    sudo driverctl unset-override" \
             "0000:${bdf}"
        exit 1
    fi
}

check_ssh_port() {
    if ss -tln 2>/dev/null \
         | grep -q ":${SSH_PORT} "; then
        echo "ERROR: Port ${SSH_PORT} already in use."
        echo "  Override with:" \
             "SSH_PORT=2223 $0 ${MODE}"
        exit 1
    fi
}

find_ernic_binary() {
    if [ -n "${ERNIC_BIN}" ] && [ -x "${ERNIC_BIN}" ]
    then
        return 0
    fi

    local search_paths=(
        "${HOME}/Projects/rocm-ernic/build/rocm_ernic"
        "${HOME}/Projects/rocm-ernic/build/rocm-ernic"
        "/usr/local/bin/rocm_ernic"
        "/usr/bin/rocm_ernic"
    )
    for p in "${search_paths[@]}"; do
        if [ -x "${p}" ]; then
            ERNIC_BIN="${p}"
            return 0
        fi
    done

    echo "ERROR: rocm-ernic binary not found."
    echo "  Set ERNIC_BIN=/path/to/rocm-ernic or"
    echo "  build rocm-ernic:"
    echo "    cd ~/Projects/rocm-ernic &&" \
         "cmake -B build -G Ninja &&" \
         "cmake --build build"
    exit 1
}

start_ernic_servers() {
    local count="${ERNIC_INSTANCES}"
    local sockets=""

    for i in $(seq 1 "${count}"); do
        local sock="/tmp/vfio-user-rocm-ernic-${i}.sock"
        rm -f "${sock}"

        echo "Starting rocm-ernic instance ${i}..."
        echo "  socket:  ${sock}"
        echo "  backend: ${ERNIC_BACKEND}"

        "${ERNIC_BIN}" \
            --socket "${sock}" \
            --backend "${ERNIC_BACKEND}" &
        ERNIC_PIDS+=($!)

        local retries=0
        while [ ! -S "${sock}" ]; do
            sleep 0.2
            retries=$((retries + 1))
            if [ ${retries} -gt 25 ]; then
                echo "ERROR: rocm-ernic did not" \
                     "create socket ${sock}"
                cleanup
                exit 1
            fi
        done
        echo "  rocm-ernic ${i} ready (pid $!)"

        if [ -z "${sockets}" ]; then
            sockets="${sock}"
        else
            sockets="${sockets},${sock}"
        fi
    done

    export VFIO_USERDEV="${sockets}"
}

check_mmio_bridge_support() {
    local qemu_bin
    qemu_bin="${QEMU_PATH:+${QEMU_PATH}/bin/}qemu-system-x86_64"
    if ! "${qemu_bin}" -device help 2>&1 \
         | grep -q 'pci-mmio-bridge'; then
        echo "ERROR: QEMU at ${qemu_bin}" \
             "does not support pci-mmio-bridge."
        echo "  rocm-xio requires a QEMU build" \
             "with PCI MMIO bridge support."
        echo "  Build QEMU >= 10.1 with the" \
             "pci-mmio-bridge device."
        exit 1
    fi
}

# Validate mode
case "${MODE}" in
    rdma|nvme|ernic|full) ;;
    *)
        echo "ERROR: Unknown mode '${MODE}'."
        echo "  Usage: $0 [rdma|nvme|ernic|full]"
        exit 1
        ;;
esac

# Validate run-vm exists
if [ ! -x "${RUN_VM}" ]; then
    echo "ERROR: run-vm not found at: ${RUN_VM}"
    echo "  Set RUN_VM=/path/to/run-vm or install" \
         "qemu-minimal."
    exit 1
fi

# Validate VM image exists
if [ ! -f "${IMAGES}/rocm-xio-vm.qcow2" ]; then
    echo "ERROR: VM image not found at:"
    echo "  ${IMAGES}/rocm-xio-vm.qcow2"
    echo "  Create it with: make gen-test-vm"
    exit 1
fi

check_ssh_port
check_mmio_bridge_support
export PCI_MMIO_BRIDGE=true

# GPU passthrough and ernic binary for all modes
case "${MODE}" in
    rdma|nvme)
        check_vfio_binding "${GPU_BDF}"
        ;;
    ernic)
        check_vfio_binding "${GPU_BDF}"
        find_ernic_binary
        ;;
    full)
        check_vfio_binding "${GPU_BDF}"
        find_ernic_binary
        ;;
esac

# Build mode-specific settings
case "${MODE}" in
    rdma)
        check_vfio_binding "${RDMA_NIC_BDF}"
        export PCI_HOSTDEV="${GPU_BDF},${RDMA_NIC_BDF}"
        ;;
    nvme)
        check_vfio_binding "${NVME_DEV_BDF}"
        export PCI_HOSTDEV="${GPU_BDF},${NVME_DEV_BDF}"
        ;;
    ernic)
        export PCI_HOSTDEV="${GPU_BDF}"
        trap cleanup SIGINT ERR EXIT
        start_ernic_servers
        ;;
    full)
        check_vfio_binding "${RDMA_NIC_BDF}"
        check_vfio_binding "${NVME_DEV_BDF}"
        export PCI_HOSTDEV="${GPU_BDF},${RDMA_NIC_BDF},${NVME_DEV_BDF}"
        trap cleanup SIGINT ERR EXIT
        start_ernic_servers
        ;;
esac

SEP="==========================================="
SEP="${SEP}=============================="

echo "${SEP}"
echo "rocm-xio Test VM  (mode: ${MODE})"
echo "${SEP}"
echo ""
echo "Devices:"
echo "  GPU:          ${GPU_BDF} (vfio-pci)"
case "${MODE}" in
    rdma)
        echo "  BNXT NIC:     ${RDMA_NIC_BDF}" \
             "(vfio-pci)"
        ;;
    nvme)
        echo "  NVMe ctrl:    ${NVME_DEV_BDF}" \
             "(vfio-pci)"
        ;;
    ernic)
        echo "  ERNIC:        ${ERNIC_INSTANCES}x" \
             "rocm-ernic (${ERNIC_BACKEND})"
        echo "  Sockets:      ${VFIO_USERDEV}"
        ;;
    full)
        echo "  BNXT NIC:     ${RDMA_NIC_BDF}" \
             "(vfio-pci)"
        echo "  NVMe ctrl:    ${NVME_DEV_BDF}" \
             "(vfio-pci)"
        echo "  ERNIC:        ${ERNIC_INSTANCES}x" \
             "rocm-ernic (${ERNIC_BACKEND})"
        echo "  Sockets:      ${VFIO_USERDEV}"
        ;;
esac
echo "  Emulated NVMe: 1x 1TB"
echo ""
echo "Networking:"
echo "  SSH: ssh -p ${SSH_PORT} user@localhost"
echo ""
echo "Serial Console:"
echo "  Ctrl-A then C  toggle QEMU monitor"
echo "  Ctrl-A then X  exit QEMU"
echo ""
echo "${SEP}"
echo "In the guest:"
echo "  sudo mount -t 9p" \
     "-o trans=virtio,version=9p2000.L \\"
echo "    hostfs /home/stebates/Projects"
echo "  cd /home/stebates/Projects/rocm-xio/build"
echo "  cmake .. -DCMAKE_BUILD_TYPE=Debug" \
     "&& make -j\$(nproc)"
echo ""
case "${MODE}" in
    rdma)
        echo "  # RDMA loopback test"
        echo "  sudo ./tests/unit/rdma-ep/" \
             "test-rdma-loopback -n 2"
        echo "  sudo ./xio-tester rdma-ep --loopback"
        ;;
    nvme)
        echo "  # NVMe endpoint test"
        echo "  sudo ./xio-tester nvme-ep"
        ;;
    ernic)
        echo "  # ERNIC loopback test"
        echo "  sudo ./tests/unit/rdma-ep/" \
             "test-rdma-ernic-loopback" \
             "--pci-mmio-bridge -n 2"
        ;;
    full)
        echo "  # RDMA loopback test"
        echo "  sudo ./tests/unit/rdma-ep/" \
             "test-rdma-loopback -n 2"
        echo "  sudo ./xio-tester rdma-ep --loopback"
        echo ""
        echo "  # NVMe endpoint test"
        echo "  sudo ./xio-tester nvme-ep"
        ;;
esac
echo "${SEP}"
echo ""

export VM_NAME=rocm-xio-vm
export VCPUS
export VMEM
export FILESYSTEM=/home/stebates/Projects
export SSH_PORT
export IMAGES
export NVME=1

exec "${RUN_VM}"
