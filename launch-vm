#!/bin/bash
# Simple VM launcher - uses already-bound devices

set -e

echo "========================================="
echo "  GDA Test VM - Simple Launcher"
echo "========================================="
echo
echo "Configuration:"
echo "  GPU:        0000:10:00.0 (already bound to vfio-pci)"
echo "  QEMU:       /opt/qemu-10.1.2"
echo "  Emulated:   1 NVMe with NVME_TRACE=all"
echo "  Filesystem: /home/stebates/Projects/rocm-axiio"
echo
echo "Starting VM..."
echo "========================================="
echo

cd /home/stebates/Projects/qemu-minimal/qemu

QEMU_PATH=/opt/qemu-10.1.2-amd-p2p/bin/ \
VM_NAME=rocm-axiio \
VCPUS=16 \
VMEM=16384 \
FILESYSTEM=/home/stebates/Projects \
NVME=1 \
NVME_TRACE=all \
NVME_TRACE_FILE=/home/stebates/Projects/rocm-axiio/nvme-gda-trace.log \
P2P_HOSTDEV=10:00.0 \
PCI_HOSTDEV=c2:00.0,c3:00.0 \
./run-vm 2>&1 | tee /home/stebates/Projects/rocm-axiio/gda-test-vm.log
