@PACKAGE_INIT@

# Find required dependencies
find_dependency(hip CONFIG REQUIRED)
find_dependency(hsa-runtime64 CONFIG REQUIRED)

# Include the exported targets
include("${CMAKE_CURRENT_LIST_DIR}/rocm-axiio-targets.cmake")

# Set convenience variables for backward compatibility
# (though using the target is preferred)
set(ROCM_AXIIO_INCLUDE_DIRS "@PACKAGE_CMAKE_INSTALL_FULL_INCLUDEDIR@/rocm-axiio")
set(ROCM_AXIIO_LIBRARIES rocm-axiio::rocm-axiio)

# Set version variables
set(ROCM_AXIIO_VERSION @PACKAGE_VERSION@)
set(ROCM_AXIIO_VERSION_MAJOR @PACKAGE_VERSION_MAJOR@)
set(ROCM_AXIIO_VERSION_MINOR @PACKAGE_VERSION_MINOR@)
set(ROCM_AXIIO_VERSION_PATCH @PACKAGE_VERSION_PATCH@)

# Verify required components
check_required_components(rocm-axiio)
