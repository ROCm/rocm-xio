 	BNXT_RE_COMP_MASK_UCNTX_RATE_LIMIT_ENABLED = 0x10,
+	BNXT_RE_COMP_MASK_UCNTX_UAPI_COMPAT_SUPPORTED = 0x20,
 };
 
 enum bnxt_re_que_flags_mask {
