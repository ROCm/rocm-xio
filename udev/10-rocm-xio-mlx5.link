#
# Rename Mellanox ConnectX (mlx5) NIC to a
# persistent rocm-xio name.  Processed by
# systemd net_setup_link at udev priority 80,
# before the default NamePolicy applies.

[Match]
Driver=mlx5_core

[Link]
Name=rocm-mlx5-0
