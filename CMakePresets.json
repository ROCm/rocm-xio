{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (Debug, tests ON)",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release (tests OFF)",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ],
  "testPresets": [
    {
      "name": "base",
      "hidden": true,
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true,
        "verbosity": "verbose"
      }
    },
    {
      "name": "unit",
      "displayName": "Unit tests (CPU-only)",
      "inherits": "base",
      "filter": { "include": { "label": "unit" } }
    },
    {
      "name": "system",
      "displayName": "System tests (GPU required)",
      "inherits": "base",
      "filter": { "include": { "label": "system" } }
    },
    {
      "name": "hardware",
      "displayName": "Hardware tests (NIC/device)",
      "inherits": "base",
      "filter": { "include": { "label": "hardware" } }
    },
    {
      "name": "sweep",
      "displayName": "Loopback sweep (multi-seed)",
      "inherits": "base",
      "filter": { "include": { "label": "sweep" } }
    },
    {
      "name": "integration",
      "displayName": "Integration tests (install + examples)",
      "inherits": "base",
      "filter": { "include": { "label": "integration" } }
    },
    {
      "name": "all",
      "displayName": "All tests",
      "inherits": "base"
    }
  ]
}
